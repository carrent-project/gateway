# Зависимости (самое важное)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Сборка и дистрибутивы (то, что генерирует компилятор)
dist/
build/
*.tsbuildinfo

# Тесты (временные файлы и отчеты)
coverage/
*.lcov
.turbo

# IDE и редакторы (папки с настройками, которые не должны попасть в репозиторий)
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Логи и метрики (чтобы логи с сервера не попали в git)
logs/
*.log
*.pid
*.seed
*.pid.lock

# Env файлы (секреты и пароли — никогда не коммитим!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Базы данных (если используешь SQLite локально)
*.db
*.sqlite
*.sqlite3

# Временные файлы ОС
Thumbs.db
Desktop.ini

# Файлы для тестов и временные артефакты
.temp
tmp/

# Docker (если используешь)
docker/data/
docker/db/
!docker/.env.example

# Config (если есть свои конфиги, кроме .env)
config/local.yml
config/development.yml